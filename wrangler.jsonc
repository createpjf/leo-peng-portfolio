{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "leo-peng-portfolio",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": true,
  "routes": [
    { "pattern": "createpjf.com/*", "zone_name": "createpjf.com" },
    { "pattern": "www.createpjf.com/*", "zone_name": "createpjf.com" }
  ]
}
