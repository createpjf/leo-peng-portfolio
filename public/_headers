# Security & caching headers — served by Cloudflare Workers static assets.
# CSP is Report-Only for now: watch the browser console / CSP reports on
# production, then promote to enforcing Content-Security-Policy once the
# Intercom messenger is confirmed unaffected.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' https://*.intercom.io https://*.intercomcdn.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.intercom.io https://*.intercomcdn.com https://*.intercomassets.com; font-src 'self' https://*.intercomcdn.com https://*.intercomassets.com; connect-src 'self' https://*.intercom.io wss://*.intercom.io https://*.intercomcdn.com https://*.intercomassets.com; media-src 'self' https://*.intercomcdn.com; frame-src https://*.intercom.io; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'

# Vite-hashed bundles: safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Unhashed media (replaced in-place if updated): cache 1 day
/*.webp
  Cache-Control: public, max-age=86400
/*.jpg
  Cache-Control: public, max-age=86400
/*.png
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400
/*.mp4
  Cache-Control: public, max-age=86400
/*.webm
  Cache-Control: public, max-age=86400
